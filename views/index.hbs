<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <meta name="description" content="{{description}}">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <div class="bg-glow"></div>

    <div class="container">
        <header>
            <h1>s2t.ai</h1>
            <p>Convert Facebook Content to Precise Text Insights</p>
        </header>

        <main>
            <div class="glass-card">
                <form id="transcribeForm">
                    <div class="form-group">
                        <label class="label" for="url">Facebook Video / Reel URL</label>
                        <input type="text" id="url" name="url" placeholder="https://www.facebook.com/watch?v=..."
                            required>
                    </div>

                    <div class="options-grid">
                        <div class="form-group">
                            <label class="label" for="mode">Output Strategy</label>
                            <select id="mode" name="mode">
                                <option value="transcript">Word-for-Word Transcript</option>
                                <option value="summary">Concise Summary</option>
                                <option value="both">Transcript & Summary</option>
                            </select>
                        </div>

                        <div class="form-group" style="display: flex; align-items: flex-end;">
                            <button type="submit" id="submitBtn">Generate Text</button>
                        </div>
                    </div>
                </form>

                <!-- Loading State -->
                <div id="loader" class="loader-container">
                    <div class="spinner"></div>
                    <p class="loading-text" id="statusText">Downloading audio from Facebook...</p>
                    <p style="color: var(--text-secondary); font-size: 0.8rem; margin-top: 0.5rem;">This may take up to
                        a minute for longer videos</p>
                </div>

                <!-- Error Message -->
                <div id="errorBox"
                    style="display: none; color: var(--error); margin-top: 2rem; padding: 1rem; background: rgba(218, 54, 51, 0.1); border-radius: 8px; border: 1px solid rgba(218, 54, 51, 0.2);">
                    <strong>Error: </strong> <span id="errorText"></span>
                </div>

                <!-- Results -->
                <div id="results" class="results-container">
                    <div class="results-header">
                        <span class="label">AI Generated Content</span>
                        <span id="modeBadge" class="badge">Transcript</span>
                    </div>
                    <div id="resultText" class="result-box"></div>
                    <button id="copyBtn"
                        style="margin-top: 1rem; background: var(--bg-card); border: 1px solid var(--border-color); font-size: 0.9rem; padding: 0.75rem;">Copy
                        to Clipboard</button>
                </div>
            </div>
        </main>
    </div>
    <script src="/js/app.js"></script>
</body>

</html>